server {
    # ${PORT} is substituted at container start (Cloud Run sets it, default 8080).
    listen       ${PORT};
    listen       [::]:${PORT};
    server_name  _;

    root   /usr/share/nginx/html;
    index  index.html;

    # Long-cache the immutable logo assets; keep HTML/JS fresh.
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
